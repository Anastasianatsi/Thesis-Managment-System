<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Thesis Announcement - Thesis Management System</title>
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Thesis Presentation Announcement</h1>
                <div>
                    <button onclick="printAnnouncement()" class="btn btn-outline-primary me-2">
                        <i class="fas fa-print me-2"></i> Print
                    </button>
                    <a href="/professor/theses/<%= thesis.id %>" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i> Back to Thesis
                    </a>
                </div>
            </div>

            <div class="card mb-4" id="announcement-card">
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h2 class="mb-3">Thesis Presentation Announcement</h2>
                        <hr class="my-4">
                    </div>

                    <div class="mb-4">
                        <h3 class="text-center">
                            <%= thesis.title %>
                        </h3>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p><strong>Student:</strong>
                                <%= thesis.student_first_name %>
                                    <%= thesis.student_last_name %>
                            </p>
                            <p><strong>Registration Number:</strong>
                                <%= thesis.registration_number %>
                            </p>
                        </div>

                        <div class="col-md-6">
                            <p><strong>Supervisor:</strong>
                                <%= thesis.supervisor_first_name %>
                                    <%= thesis.supervisor_last_name %>
                            </p>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5>Thesis Summary</h5>
                        <p>
                            <%= thesis.summary %>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h5>Presentation Details</h5>
                        <p><strong>Date and Time:</strong>
                            <%= new Date(presentation.presentation_date).toLocaleString() %>
                        </p>
                        <p>
                            <strong>Location:</strong>
                            <% if (presentation.is_online) { %>
                                <a href="<%= presentation.location %>">
                                    <%= presentation.location %>
                                </a>
                                <span class="badge bg-info ms-2">Online</span>
                                <% } else { %>
                                    <%= presentation.location %>
                                        <span class="badge bg-secondary ms-2">In Person</span>
                                        <% } %>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h5>Examination Committee</h5>
                        <ol>
                            <li><strong>
                                    <%= thesis.supervisor_first_name %>
                                        <%= thesis.supervisor_last_name %>
                                </strong> (Supervisor)</li>
                            <% committeeMembers.forEach((member, index)=> { %>
                                <li><strong>
                                        <%= member.first_name %>
                                            <%= member.last_name %>
                                    </strong> (Committee Member)</li>
                                <% }) %>
                        </ol>
                    </div>

                    <div class="mt-5">
                        <p class="text-center">All interested parties are invited to attend.</p>
                    </div>

                    <div class="mt-5 text-end">
                        <p>Date: <%= new Date().toLocaleDateString() %>
                        </p>
                        <p>Department of Computer Engineering & Informatics</p>
                    </div>
                </div>
            </div>
        </div>

        <script>
            function printAnnouncement() {
                const printContents = document.getElementById('announcement-card').innerHTML;
                const originalContents = document.body.innerHTML;

                document.body.innerHTML = `
        <div class="container mt-4">
          <div class="card">
            ${printContents}
          </div>
        </div>
      `;

                window.print();
                document.body.innerHTML = originalContents;
            }
        </script>

        <%- include('../partials/footer') %>
</body>

</html>