<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
    <title>All Students - Thesis Management System</title>
</head>

<body>
  <%- include('../partials/navbar') %>

    <div class="container mt-4">
      <div class="row justify-content-center">
        <div class="col-md-10">
          <div class="card">
            <div class="card-header bg-primary text-white">
              <h4 class="mb-0">All Students</h4>
            </div>
            <div class="card-body">
              <div id="student-table-container">
                <p class="text-muted">Loading students...</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <%- include('../partials/messages') %>
    <%- include('../partials/footer') %>
    <script>
        const topicId = window.location.pathname.split('/')[3];
      console.log({ topicId });
      
        // Call this function when assigning a thesis topic to a student
        async function assignThesisToStudent(topicId, studentId) {
          console.log({ topicId, studentId });
          
          try {
            const response = await fetch(`/professor/topics/${topicId}/assign`, {
              method: "POST",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({ studentId })
            })

            if (response.redirected) {
              // If the server redirects, follow the redirect
              window.location.href = response.url
              return
            }

            if (!response.ok) {
              const error = await response.text()
              throw new Error(error)
            }

            // Optionally handle success (e.g., show a message or reload)
            alert("Thesis topic assigned successfully!")
            window.location.reload()
          } catch (err) {
            alert("Failed to assign thesis topic: " + err.message)
          }
        }

        document.addEventListener("DOMContentLoaded", () => {
          fetch('/professor/students')
            .then(response => {
              if (!response.ok) throw new Error("Failed to fetch students")
              return response.json()
            })
            .then(students => {
              const container = document.getElementById("student-table-container")
              if (!students.length) {
                container.innerHTML = '<p class="text-muted">No students found.</p>'
                return
              }

              const table = document.createElement("table")
              table.className = "table table-striped"
              table.innerHTML = `
            <thead>
              <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Registration Number</th>
                <th>Email</th>
              </tr>
            </thead>
            <tbody>
              ${students.map((student, index) => `
                <tr>
                  <td>${index + 1}</td>
                  <td>${student.first_name} ${student.last_name}</td>
                  <td>${student.registration_number}</td>
                  <td>
                    <button class="btn btn-sm btn-success assign-topic-btn" data-student-id="${student.id}" onclick="assignThesisToStudent(${topicId}, ${student.id})">
                      Assign Topic
                    </button>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          `

              container.innerHTML = ''
              container.appendChild(table)
            })
            .catch(error => {
              console.error("Error fetching students:", error)
              document.getElementById("student-table-container").innerHTML = '<p class="text-danger">Failed to load students.</p>'
            })
        })
      </script>
</body>

</html>