<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Committee Invitations - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Committee Invitations</h1>
      <a href="/professor/dashboard" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
      </a>
    </div>
    
    <%- include('../partials/messages') %>
    
    <% if (invitations.length === 0) { %>
      <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i> You don't have any pending invitations.
      </div>
    <% } else { %>
      <div class="row">
        <% invitations.forEach(invitation => { %>
          <div class="col-md-6 mb-4">
            <div class="card">
              <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Invitation to Committee</h5>
              </div>
              <div class="card-body">
                <h5><%= invitation.title %></h5>
                
                <div class="mt-3">
                  <p><strong>Student:</strong> <%= invitation.student_first_name %> <%= invitation.student_last_name %></p>
                  <p><strong>Supervisor:</strong> <%= invitation.supervisor_first_name %> <%= invitation.supervisor_last_name %></p>
                  <p><strong>Invited on:</strong> <%= new Date(invitation.invitation_date).toLocaleDateString() %></p>
                </div>
                
                <div class="d-grid gap-2 mt-4">
                  <form action="/professor/invitations/<%= invitation.id %>/respond" method="POST">
                    <input type="hidden" name="response" value="accepted">
                    <button type="submit" class="btn btn-success w-100 mb-2">
                      <i class="fas fa-check-circle me-2"></i> Accept Invitation
                    </button>
                  </form>
                  
                  <form action="/professor/invitations/<%= invitation.id %>/respond" method="POST">
                    <input type="hidden" name="response" value="rejected">
                    <button type="submit" class="btn btn-danger w-100">
                      <i class="fas fa-times-circle me-2"></i> Decline Invitation
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
