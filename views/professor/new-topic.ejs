<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Create Thesis Topic - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create New Thesis Topic</h4>
          </div>
          <div class="card-body">
            <%- include('../partials/messages') %>
            
            <form action="/professor/topics" method="POST" enctype="multipart/form-data">
              <div class="mb-3">
                <label for="title" class="form-label required-field">Title</label>
                <input type="text" class="form-control" id="title" name="title" required>
                <div class="form-text">Provide a clear and concise title for the thesis topic.</div>
              </div>
              
              <div class="mb-3">
                <label for="summary" class="form-label required-field">Summary</label>
                <textarea class="form-control" id="summary" name="summary" rows="5" required></textarea>
                <div class="form-text">Provide a brief summary of the thesis topic (max 500 words).</div>
              </div>
              
              <div class="mb-3">
                <label for="description" class="form-label">Description File (PDF)</label>
                <input type="file" class="form-control" id="description" name="description" accept=".pdf">
                <div class="form-text">Upload a detailed description of the thesis topic (optional).</div>
              </div>
              
              <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a href="/professor/topics" class="btn btn-outline-secondary me-md-2">Cancel</a>
                <button type="submit" class="btn btn-primary">Create Topic</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
