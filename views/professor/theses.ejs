<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Thesis Assignments - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <h1 class="mb-4">Thesis Assignments</h1>
    
    <%- include('../partials/messages') %>
    
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Filter by Status</h5>
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
              <a href="/professor/theses?status=all&role=<%= role %>" class="btn <%= status === 'all' ? 'btn-primary' : 'btn-outline-primary' %>">All</a>
              <a href="/professor/theses?status=pending&role=<%= role %>" class="btn <%= status === 'pending' ? 'btn-primary' : 'btn-outline-primary' %>">Pending</a>
              <a href="/professor/theses?status=active&role=<%= role %>" class="btn <%= status === 'active' ? 'btn-primary' : 'btn-outline-primary' %>">Active</a>
              <a href="/professor/theses?status=under_review&role=<%= role %>" class="btn <%= status === 'under_review' ? 'btn-primary' : 'btn-outline-primary' %>">Under Review</a>
              <a href="/professor/theses?status=completed&role=<%= role %>" class="btn <%= status === 'completed' ? 'btn-primary' : 'btn-outline-primary' %>">Completed</a>
              <a href="/professor/theses?status=cancelled&role=<%= role %>" class="btn <%= status === 'cancelled' ? 'btn-primary' : 'btn-outline-primary' %>">Cancelled</a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="col-md-6">
        <div class="card">
          <div class="card-header bg-info text-white">
            <h5 class="mb-0">Filter by Role</h5>
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
              <a href="/professor/theses?status=<%= status %>&role=all" class="btn <%= role === 'all' ? 'btn-info' : 'btn-outline-info' %>">All</a>
              <a href="/professor/theses?status=<%= status %>&role=supervisor" class="btn <%= role === 'supervisor' ? 'btn-info' : 'btn-outline-info' %>">As Supervisor</a>
              <a href="/professor/theses?status=<%= status %>&role=committee" class="btn <%= role === 'committee' ? 'btn-info' : 'btn-outline-info' %>">As Committee Member</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <% if (theses.length === 0) { %>
      <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i> No thesis assignments found with the selected filters.
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Title</th>
              <th>Student</th>
              <th>Status</th>
              <th>Assignment Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% theses.forEach(thesis => { %>
              <tr>
                <td><%= thesis.title %></td>
                <td><%= thesis.student_first_name %> <%= thesis.student_last_name %> (<%= thesis.registration_number %>)</td>
                <td>
                  <span class="badge status-<%= thesis.status %>">
                    <%= thesis.status.replace('_', ' ').toUpperCase() %>
                  </span>
                </td>
                <td>
                  <% if (thesis.assignment_date) { %>
                    <%= new Date(thesis.assignment_date).toLocaleDateString() %>
                  <% } else { %>
                    <span class="text-muted">Not yet assigned</span>
                  <% } %>
                </td>
                <td>
                  <a href="/professor/theses/<%= thesis.id %>" class="btn btn-sm btn-primary">
                    <i class="fas fa-eye"></i> View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      
      <div class="mt-3">
        <a href="/professor/theses/export?status=<%= status %>&role=<%= role %>&format=csv" class="btn btn-outline-secondary me-2">
          <i class="fas fa-file-csv me-2"></i> Export as CSV
        </a>
        <a href="/professor/theses/export?status=<%= status %>&role=<%= role %>&format=json" class="btn btn-outline-secondary">
          <i class="fas fa-file-code me-2"></i> Export as JSON
        </a>
      </div>
    <% } %>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
