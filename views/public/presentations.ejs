<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Thesis Presentations - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <h1 class="mb-4">Upcoming Thesis Presentations</h1>
    
    <div class="card mb-4">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Filter by Date</h5>
      </div>
      <div class="card-body">
        <form action="/public/presentations" method="GET" class="row g-3">
          <div class="col-md-4">
            <label for="start" class="form-label">Start Date</label>
            <input type="date" class="form-control" id="start" name="start" value="<%= startDate %>">
          </div>
          
          <div class="col-md-4">
            <label for="end" class="form-label">End Date</label>
            <input type="date" class="form-control" id="end" name="end" value="<%= endDate %>">
          </div>
          
          <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Apply Filter</button>
          </div>
        </form>
        
        <div class="mt-3">
          <div class="btn-group">
            <a href="/public/presentations?start=<%= startDate %>&end=<%= endDate %>&format=json" class="btn btn-outline-secondary">
              <i class="fas fa-file-code me-2"></i> JSON
            </a>
            <a href="/public/presentations?start=<%= startDate %>&end=<%= endDate %>&format=xml" class="btn btn-outline-secondary">
              <i class="fas fa-file-code me-2"></i> XML
            </a>
          </div>
        </div>
      </div>
    </div>
    
    <% if (presentations.length === 0) { %>
      <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i> No presentations scheduled for the selected date range.
      </div>
    <% } else { %>
      <div class="row">
        <% presentations.forEach(presentation => { %>
          <div class="col-md-6 mb-4">
            <div class="card h-100">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><%= presentation.title %></h5>
              </div>
              <div class="card-body">
                <p><strong>Student:</strong> <%= presentation.student_first_name %> <%= presentation.student_last_name %></p>
                <p><strong>Supervisor:</strong> <%= presentation.supervisor_first_name %> <%= presentation.supervisor_last_name %></p>
                
                <p>
                  <strong>Date and Time:</strong> <%= new Date(presentation.presentation_date).toLocaleString() %>
                </p>
                
                <p>
                  <strong>Location:</strong> 
                  <% if (presentation.is_online) { %>
                    <a href="<%= presentation.location %>" target="_blank"><%= presentation.location %></a>
                    <span class="badge bg-info ms-2">Online</span>
                  <% } else { %>
                    <%= presentation.location %>
                    <span class="badge bg-secondary ms-2">In Person</span>
                  <% } %>
                </p>
                
                <div class="mt-3">
                  <h6>Committee Members:</h6>
                  <ul class="list-group">
                    <% presentation.committeeMembers.forEach(member => { %>
                      <li class="list-group-item"><%= member.first_name %> <%= member.last_name %></li>
                    <% }) %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
