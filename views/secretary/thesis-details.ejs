<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Thesis Details - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Thesis Details</h1>
      <a href="/secretary/theses" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i> Back to List
      </a>
    </div>
    
    <%- include('../partials/messages') %>
    
    <div class="row">
      <div class="col-md-8">
        <div class="card mb-4">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Basic Information</h5>
          </div>
          <div class="card-body">
            <h4><%= thesis.title %></h4>
            <p class="text-muted">
              <span class="badge status-<%= thesis.status %>">
                <%= thesis.status.replace('_', ' ').toUpperCase() %>
              </span>
            </p>
            
            <div class="row mt-4">
              <div class="col-md-6">
                <h5>Student</h5>
                <p><%= thesis.student_first_name %> <%= thesis.student_last_name %></p>
                <p>Registration Number: <%= thesis.registration_number %></p>
              </div>
              
              <div class="col-md-6">
                <h5>Supervisor</h5>
                <p><%= thesis.supervisor_first_name %> <%= thesis.supervisor_last_name %></p>
              </div>
            </div>
            
            <div class="mt-4">
              <h5>Summary</h5>
              <p><%= thesis.summary %></p>
            </div>
            
            <% if (thesis.faculty_meeting_number) { %>
              <div class="mt-4">
                <h5>Faculty Meeting Information</h5>
                <p>Meeting Number: <%= thesis.faculty_meeting_number %></p>
                <p>Meeting Year: <%= thesis.faculty_meeting_year %></p>
              </div>
            <% } %>
            
            <% if (thesis.repository_link) { %>
              <div class="mt-4">
                <h5>Repository Link</h5>
                <a href="<%= thesis.repository_link %>" target="_blank" class="btn btn-outline-info">
                  <i class="fas fa-external-link-alt me-2"></i> View in Repository
                </a>
              </div>
            <% } %>
          </div>
        </div>
        
        <div class="card mb-4">
          <div class="card-header bg-info text-white">
            <h5 class="mb-0">Committee Members</h5>
          </div>
          <div class="card-body">
            <% if (committeeMembers.length === 0) { %>
              <p class="text-muted">No committee members have been assigned yet.</p>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-striped">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Status</th>
                      <th>Invitation Date</th>
                      <th>Response Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% committeeMembers.forEach(member => { %>
                      <tr>
                        <td><%= member.first_name %> <%= member.last_name %></td>
                        <td>
                          <% if (member.status === 'pending') { %>
                            <span class="badge bg-warning text-dark">Pending</span>
                          <% } else if (member.status === 'accepted') { %>
                            <span class="badge bg-success">Accepted</span>
                          <% } else { %>
                            <span class="badge bg-danger">Rejected</span>
                          <% } %>
                        </td>
                        <td><%= new Date(member.invitation_date).toLocaleString() %></td>
                        <td>
                          <% if (member.response_date) { %>
                            <%= new Date(member.response_date).toLocaleString() %>
                          <% } else { %>
                            <span class="text-muted">No response yet</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
        
        <% if (submission) { %>
          <div class="card mb-4">
            <div class="card-header bg-success text-white">
              <h5 class="mb-0">Thesis Submission</h5>
            </div>
            <div class="card-body">
              <p>
                <strong>Submitted:</strong> <%= new Date(submission.created_at).toLocaleString() %>
              </p>
              
              <div class="mt-3">
                <a href="/uploads/<%= submission.document_path %>" target="_blank" class="btn btn-outline-primary">
                  <i class="fas fa-file-alt me-2"></i> View Document
                </a>
              </div>
              
              <% if (submission.additional_links) { %>
                    <div class="mt-4">
                      <h6>Additional Resource</h6>
                      <a href="<%= submission.additional_links.trim() %>" target="_blank" class="btn btn-outline-secondary">
                        <i class="fas fa-link me-2"></i> View Resource
                      </a>
                    </div>
              <% } %>
            </div>
          </div>
        <% } %>
        
        <% if (presentation) { %>
          <div class="card mb-4">
            <div class="card-header bg-warning text-dark">
              <h5 class="mb-0">Presentation Details</h5>
            </div>
            <div class="card-body">
              <p>
                <strong>Date and Time:</strong> <%= new Date(presentation.presentation_date).toLocaleString() %>
              </p>
              
              <p>
                <strong>Location:</strong> 
                <% if (presentation.is_online) { %>
                  <a href="<%= presentation.location %>" target="_blank"><%= presentation.location %></a>
                  <span class="badge bg-info ms-2">Online</span>
                <% } else { %>
                  <%= presentation.location %>
                  <span class="badge bg-secondary ms-2">In Person</span>
                <% } %>
              </p>
            </div>
          </div>
        <% } %>
        
        <% if (evaluations.length > 0) { %>
          <div class="card mb-4">
            <div class="card-header bg-success text-white">
              <h5 class="mb-0">Evaluations</h5>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-striped">
                  <thead>
                    <tr>
                      <th>Evaluator</th>
                      <th>Content</th>
                      <th>Presentation</th>
                      <th>Technical</th>
                      <th>Innovation</th>
                      <th>Final Grade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% evaluations.forEach(evaluation => { %>
                      <tr>
                        <td><%= evaluation.first_name %> <%= evaluation.last_name %></td>
                        <td><%= evaluation.content_quality %></td>
                        <td><%= evaluation.presentation_quality %></td>
                        <td><%= evaluation.technical_quality %></td>
                        <td><%= evaluation.innovation %></td>
                        <td><strong><%= evaluation.final_grade %></strong></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              
              <% if (averageGrade) { %>
                <div class="alert alert-success mt-3">
                  <h5 class="mb-0">Average Grade: <%= averageGrade %></h5>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
      
      <div class="col-md-4">
        <div class="card mb-4">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Actions</h5>
          </div>
          <div class="card-body">
            <% if (thesis.status === 'active') { %>
              <% if (!thesis.faculty_meeting_number) { %>
                <button type="button" class="btn btn-info w-100 mb-3" data-bs-toggle="modal" data-bs-target="#meetingModal">
                  <i class="fas fa-university me-2"></i> Add Faculty Meeting Info
                </button>
              <% } %>
              
              <button type="button" class="btn btn-danger w-100 mb-3" data-bs-toggle="modal" data-bs-target="#cancelModal">
                <i class="fas fa-times-circle me-2"></i> Cancel Thesis
              </button>
            <% } else if (thesis.status === 'under_review') { %>
              <% if (evaluations.length >= 3 && thesis.repository_link) { %>
                <form action="/secretary/theses/<%= thesis.id %>/complete" method="POST" class="mb-3">
                  <button type="submit" class="btn btn-success w-100" onclick="return confirm('Are you sure you want to mark this thesis as completed?')">
                    <i class="fas fa-check-circle me-2"></i> Mark as Completed
                  </button>
                </form>
              <% } else { %>
                <div class="alert alert-warning">
                  <i class="fas fa-exclamation-triangle me-2"></i> Cannot mark as completed until all evaluations are submitted and repository link is provided.
                </div>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Faculty Meeting Modal -->
  <div class="modal fade" id="meetingModal" tabindex="-1" aria-labelledby="meetingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="meetingModalLabel">Add Faculty Meeting Information</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/secretary/theses/<%= thesis.id %>/meeting" method="POST">
          <div class="modal-body">
            <div class="mb-3">
              <label for="meetingNumber" class="form-label">Meeting Number</label>
              <input type="text" class="form-control" id="meetingNumber" name="meetingNumber" required>
            </div>
            
            <div class="mb-3">
              <label for="meetingYear" class="form-label">Meeting Year</label>
              <input type="text" class="form-control" id="meetingYear" name="meetingYear" required>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <!-- Cancel Thesis Modal -->
  <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="cancelModalLabel">Cancel Thesis</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/secretary/theses/<%= thesis.id %>/cancel" method="POST">
          <div class="modal-body">
            <div class="alert alert-danger">
              <i class="fas fa-exclamation-triangle me-2"></i> Are you sure you want to cancel this thesis assignment? This action cannot be undone.
            </div>
            
            <div class="mb-3">
              <label for="cancellationMeetingNumber" class="form-label">Cancellation Meeting Number</label>
              <input type="text" class="form-control" id="cancellationMeetingNumber" name="cancellationMeetingNumber" required>
            </div>
            
            <div class="mb-3">
              <label for="cancellationMeetingYear" class="form-label">Cancellation Meeting Year</label>
              <input type="text" class="form-control" id="cancellationMeetingYear" name="cancellationMeetingYear" required>
            </div>
            
            <div class="mb-3">
              <label for="cancellationReason" class="form-label">Cancellation Reason</label>
              <textarea class="form-control" id="cancellationReason" name="cancellationReason" rows="3" required></textarea>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
