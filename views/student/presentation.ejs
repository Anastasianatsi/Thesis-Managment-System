<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <title>Set Presentation Details - Thesis Management System</title>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Set Presentation Details</h4>
          </div>
          <div class="card-body">
            <%- include('../partials/messages') %>
            
            <div class="mb-4">
              <h5>Thesis Details</h5>
              <p><strong>Title:</strong> <%= thesis.title %></p>
            </div>
            
            <% if (presentation) { %>
              <div class="alert alert-success mb-4">
                <i class="fas fa-check-circle me-2"></i> You have already set your presentation details.
                <div class="mt-2">
                  <strong>Date and Time:</strong> <%= new Date(presentation.presentation_date).toLocaleString() %>
                </div>
                <div class="mt-2">
                  <strong>Location:</strong> 
                  <% if (presentation.is_online) { %>
                    <a href="<%= presentation.location %>" target="_blank"><%= presentation.location %></a>
                    <span class="badge bg-info ms-2">Online</span>
                  <% } else { %>
                    <%= presentation.location %>
                    <span class="badge bg-secondary ms-2">In Person</span>
                  <% } %>
                </div>
              </div>
            <% } %>
            
            <form action="/student/thesis/presentation" method="POST">
              <div class="row mb-3">
                <div class="col-md-6">
                  <label for="presentationDate" class="form-label required-field">Presentation Date</label>
                  <input type="date" class="form-control" id="presentationDate" name="presentationDate" required>
                </div>
                
                <div class="col-md-6">
                  <label for="presentationTime" class="form-label required-field">Presentation Time</label>
                  <input type="time" class="form-control" id="presentationTime" name="presentationTime" required>
                </div>
              </div>
              
              <div class="mb-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="isOnline" name="isOnline">
                  <label class="form-check-label" for="isOnline">
                    Online Presentation
                  </label>
                </div>
              </div>
              
              <div class="mb-3">
                <label for="location" class="form-label required-field">Location</label>
                <input type="text" class="form-control" id="location" name="location" required>
                <div class="form-text">
                  For in-person presentations, enter the room number. For online presentations, enter the meeting link.
                </div>
              </div>
              
              <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a href="/student/dashboard" class="btn btn-outline-secondary me-md-2">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Presentation Details</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
</body>
</html>
